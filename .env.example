# Shopify App Credentials
SHOPIFY_API_KEY=your_api_key_here
SHOPIFY_API_SECRET=your_api_secret_here

# App URL (the public URL of this deployment, e.g. your Coolify domain)
SHOPIFY_APP_URL=https://your-app-url.com

# Database URL — PostgreSQL connection string (provided by Coolify)
DATABASE_URL="postgresql://user:password@host:5432/hidestock"

# Scopes required by the app
SCOPES=read_products,read_inventory,read_themes

# Optional: Custom shop domain
# SHOP_CUSTOM_DOMAIN=myshop.com

# Billing is handled by Shopify Managed Pricing (set up your plan + price in the
# Partner Dashboard → Pricing). The app makes no Billing API calls, so there are no
# billing env vars to configure here.
