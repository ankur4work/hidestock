# Shopify App Credentials
SHOPIFY_API_KEY=your_api_key_here
SHOPIFY_API_SECRET=your_api_secret_here

# App URL (the public URL of this deployment, e.g. your Coolify domain)
SHOPIFY_APP_URL=https://your-app-url.com

# Database URL — PostgreSQL connection string (provided by Coolify)
DATABASE_URL="postgresql://user:password@host:5432/hidestock"

# Scopes required by the app
SCOPES=read_products,read_inventory,read_themes

# Optional: Custom shop domain
# SHOP_CUSTOM_DOMAIN=myshop.com

# Billing master switch. Set to "false" when using Shopify "Managed Pricing" (Shopify
# collects payment before the app opens; the app-managed Billing API is disabled and would
# 403). Set to "true" to use the in-app Billing API gate below. Default: true.
APP_BILLING_ENABLED=true

# Billing (Shopify Billing API, app-managed) — change price/trial via env, no code changes.
# Keep APP_PLAN_NAME stable: existing subscriptions are matched by plan name. Changing the
# PRICE only affects NEW subscribers; current subscribers keep their original price.
APP_PLAN_NAME=Pro
APP_PLAN_PRICE=20
APP_PLAN_CURRENCY=USD
APP_TRIAL_DAYS=3
# Set to "true" on dev/staging to create test charges (no real money). "false" in production.
APP_BILLING_TEST=false
